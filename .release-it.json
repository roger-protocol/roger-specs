{
  "$schema": "https://unpkg.com/release-it@latest/schema/release-it.json",
  "git": {
    "requireBranch": ["main", "v*"],
    "commitMessage": "chore(release): ${version}",
    "tagName": "v${version}"
  },
  "npm": {
    "publish": true
  },
  "hooks": {
    "before:init": ["npm run lint"],
    "after:bump": ["cross-env NODE_AUTH_TOKEN= GITHUB_TOKEN= npm run build"]
  },
  "github": {
    "release": true,
    "autoGenerate": true
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits"
      },
      "infile": "CHANGELOG.md"
    }
  }
}
