{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "paths": {
      "@/*": ["./src/*"],
    },
  },
  "include": ["src/**/*", "eslint.config.ts", "tsup.config.ts"],
}
